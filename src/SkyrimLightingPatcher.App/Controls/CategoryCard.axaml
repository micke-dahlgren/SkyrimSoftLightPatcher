<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:SkyrimLightingPatcher.App.Controls"
             x:Class="SkyrimLightingPatcher.App.Controls.CategoryCard"
             x:DataType="controls:CategoryCard"
             x:Name="Root">
  <StackPanel Spacing="10">
    <TextBlock Classes="section-title" Text="{Binding #Root.Title}" />
    <TextBlock Foreground="{DynamicResource TextBody}"
               Text="{Binding #Root.Description}"
               TextWrapping="Wrap" />
    <CheckBox Content="{Binding #Root.CheckBoxText}" IsChecked="{Binding #Root.IsChecked, Mode=TwoWay}" />
    <Border CornerRadius="6" HorizontalAlignment="Left">
      <Grid Width="300" Height="146" ClipToBounds="True">
        <Image Source="{Binding #Root.EnabledImage}"
               Stretch="UniformToFill"
               IsVisible="{Binding #Root.IsChecked}" />
        <Image Source="{Binding #Root.DisabledImage}"
               Stretch="UniformToFill"
               IsVisible="{Binding #Root.IsChecked, Converter={x:Static BoolConverters.Not}}" />
      </Grid>
    </Border>
  </StackPanel>
</UserControl>
