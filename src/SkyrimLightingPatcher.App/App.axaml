<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="SkyrimLightingPatcher.App.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <fluent:FluentTheme />
    <StyleInclude Source="avares://SkyrimLightingPatcher.App/Styles/Theme.axaml" />

    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundDark}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBody}" />
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundLight}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextHeader}" />
    </Style>

    <Style Selector="Slider">
      <Setter Property="Foreground" Value="{DynamicResource CTA}" />
    </Style>

    <Style Selector="Slider:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource CTAHover}" />
    </Style>

    <Style Selector="Slider /template/ Thumb">
      <Setter Property="Background" Value="{DynamicResource CTA}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTA}" />
      <Setter Property="Foreground" Value="{DynamicResource CTA}" />
    </Style>

    <Style Selector="Slider /template/ Thumb#horizontalThumb">
      <Setter Property="Background" Value="{DynamicResource CTA}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTA}" />
      <Setter Property="Foreground" Value="{DynamicResource CTA}" />
    </Style>

    <Style Selector="Slider /template/ Thumb#verticalThumb">
      <Setter Property="Background" Value="{DynamicResource CTA}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTA}" />
      <Setter Property="Foreground" Value="{DynamicResource CTA}" />
    </Style>

    <Style Selector="Slider:pointerover /template/ Thumb">
      <Setter Property="Background" Value="{DynamicResource CTAHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTAHover}" />
      <Setter Property="Foreground" Value="{DynamicResource CTAHover}" />
    </Style>

    <Style Selector="Slider:pointerover /template/ Thumb#horizontalThumb">
      <Setter Property="Background" Value="{DynamicResource CTAHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTAHover}" />
      <Setter Property="Foreground" Value="{DynamicResource CTAHover}" />
    </Style>

    <Style Selector="Slider:pointerover /template/ Thumb#verticalThumb">
      <Setter Property="Background" Value="{DynamicResource CTAHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTAHover}" />
      <Setter Property="Foreground" Value="{DynamicResource CTAHover}" />
    </Style>

    <Style Selector="Slider /template/ RepeatButton#HorizontalDecreaseButton">
      <Setter Property="Background" Value="{DynamicResource CTA}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTA}" />
    </Style>

    <Style Selector="Slider:pointerover /template/ RepeatButton#HorizontalDecreaseButton">
      <Setter Property="Background" Value="{DynamicResource CTAHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTAHover}" />
    </Style>

    <Style Selector="Slider /template/ RepeatButton#VerticalDecreaseButton">
      <Setter Property="Background" Value="{DynamicResource CTA}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTA}" />
    </Style>

    <Style Selector="Slider:pointerover /template/ RepeatButton#VerticalDecreaseButton">
      <Setter Property="Background" Value="{DynamicResource CTAHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CTAHover}" />
    </Style>
  </Application.Styles>
</Application>
